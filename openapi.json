            "type": "string",
            "example": "Les Misérables"
          },
          "isbn": {
            "type": "string",
            "example": "978-2070409189"
          },
          "publishedYear": {
            "type": "number",
            "example": 1862
          },
          "totalCopies": {
            "type": "number",
            "example": 5
          },
          "availableCopies": {
            "type": "number",
            "example": 5
          },
          "summary": {
            "type": "string",
            "example": "Roman historique et social."
          },
          "coverUrl": {
            "type": "string",
            "example": "https://example.com/cover.jpg"
          },
          "categoryId": {
            "type": "number",
            "example": 1
          },
          "authorIds": {
            "example": [1, 2],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "CreateLoanDto": {
        "type": "object",
        "properties": {
          "dueDate": {
            "type": "string",
            "example": "2026-04-20T10:00:00.000Z"
          },
          "userId": {
            "type": "number",
            "example": 1
          },
          "bookId": {
            "type": "number",
            "example": 1
          }
        },
        "required": ["dueDate", "userId", "bookId"]
      },
      "UpdateLoanDto": {
        "type": "object",
        "properties": {
          "dueDate": {
            "type": "string",
            "example": "2026-04-20T10:00:00.000Z"
          },
          "userId": {
            "type": "number",
            "example": 1
          },
          "bookId": {
            "type": "number",
            "example": 1
          },
          "returnedAt": {
            "type": "string",
            "example": "2026-04-18T14:00:00.000Z"
          },
          "status": {
            "type": "string",
            "example": "RETURNED",
            "enum": ["BORROWED", "RETURNED"]
          }
        }
      }
    }
