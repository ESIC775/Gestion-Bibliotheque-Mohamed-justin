          },
          "phone": {
            "type": "string",
            "example": "+33601020304"
          },
          "membershipNumber": {
            "type": "string",
            "example": "MEM-2026-001"
          },
          "joinedAt": {
            "type": "string",
            "example": "2026-04-15T10:00:00.000Z"
          },
          "userId": {
            "type": "number",
            "example": 1
          }
        }
      },
      "CreateAuthorDto": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "example": "Victor"
          },
          "lastName": {
            "type": "string",
            "example": "Hugo"
          },
          "bio": {
            "type": "string",
            "example": "Écrivain français majeur du XIXe siècle."
          }
        },
        "required": ["firstName", "lastName"]
      },
      "UpdateAuthorDto": {
        "type": "object",
        "properties": {
          "firstName": {
